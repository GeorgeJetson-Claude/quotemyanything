GROQ_API_KEY=your_groq_key_here
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# --- 5LUV YouTube Publisher (youtube_publisher.py) ---
# OAuth client secrets JSON from Google Cloud Console (Desktop app). See YOUTUBE_SETUP.md
YT_CLIENT_SECRETS=agents/yt_client_secret.json
YT_TOKEN_PATH=agents/yt_token.json
YT_QUEUE_PATH=agents/youtube_queue.json
# How many videos to release per run and how many hours apart to drip scheduled drops
YT_MAX_PER_RUN=3
YT_DRIP_HOURS=8
